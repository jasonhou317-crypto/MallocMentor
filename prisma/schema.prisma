// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// =============================================
// NextAuth.js 所需模型
// =============================================

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// =============================================
// 业务模型
// =============================================

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?   // bcrypt 哈希密码（Credentials 登录）
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts           Account[]
  sessions           Session[]
  capabilityRadar    CapabilityRadar?
  interviewSessions  InterviewSession[]
  learningPaths      LearningPath[]
  submissions        CodeSubmission[]
  activityLogs       ActivityLog[]
  learningProgress   UserLearningProgress[]
  favorites          UserFavorite[]
  achievements       UserAchievement[]
}

// 能力雷达图模型 - 6维能力评估
model CapabilityRadar {
  id                String   @id @default(cuid())
  userId            String   @unique
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // 六个维度的得分 (0-100)
  basicSyntax       Int      @default(0)  // 基础语法
  memoryManagement  Int      @default(0)  // 内存管理
  dataStructures    Int      @default(0)  // 数据结构与算法
  oop               Int      @default(0)  // 面向对象设计
  stlLibrary        Int      @default(0)  // STL/库使用
  systemProgramming Int      @default(0)  // 系统编程能力

  updatedAt         DateTime @updatedAt
}

// 题目模型
model Problem {
  id          String   @id @default(cuid())
  title       String
  description String   @db.Text
  difficulty  String   // Easy, Medium, Hard
  category    String   // 分类：指针、内存、STL等
  tags        String   // JSON数组存储标签

  testCases   String   @db.Text // JSON存储测试用例

  hints       String?  @db.Text
  solution    String?  @db.Text

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  submissions CodeSubmission[]
}

// 代码提交记录
model CodeSubmission {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  problemId   String
  problem     Problem  @relation(fields: [problemId], references: [id], onDelete: Cascade)

  code        String   @db.Text
  language    String   // C or C++
  status      String   // Passed, Failed, Error

  aiReview    String?  @db.Text

  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([problemId])
}

// 面试会话模型
model InterviewSession {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  title       String
  type        String   // Technical, Behavioral
  status      String   // Active, Completed
  templateId  String?  // 关联面试模板

  messages    String   @db.Text  // JSON格式对话历史
  cozeSessionId String? // Coze 多轮对话 session ID

  evaluation  String?  @db.Text  // AI评估报告

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
}

// 学习路径模型
model LearningPath {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  title       String
  description String   @db.Text

  steps       String   @db.Text  // JSON格式步骤（含 articleIds 关联知识库文章）

  currentStep Int      @default(0)
  progress    Int      @default(0) // 0-100

  status      String   @default("active") // active, completed, paused

  order       Int      @default(0)  // 路径阶段序号，用于排序与解锁判断
  templateId  String?               // 关联模板标识，null 表示 AI 生成或自定义路径

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
}

// =============================================
// 知识库模型
// =============================================

// 知识库文章
model KnowledgeArticle {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  filePath    String   // content/articles/ 下的 .md 文件相对路径
  category    String
  tags        String   // JSON 数组
  difficulty  String   // Easy, Medium, Hard
  author      String   @default("MallocMentor")
  views       Int      @default(0)
  likes       Int      @default(0)
  summary     String   @db.Text
  estimatedTime Int    @default(15) // 预计阅读时间（分钟）

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  learningProgress UserLearningProgress[]
  favorites        UserFavorite[]
}

// 用户收藏
model UserFavorite {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  articleId String
  article   KnowledgeArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, articleId])
  @@index([userId])
}

// 知识库分类
model KnowledgeCategory {
  id           String  @id @default(cuid())
  name         String  @unique // 英文标识，如 basics, pointer
  label        String          // 中文标签，如 基础语法
  icon         String?         // 图标名称
  description  String?
  articleCount Int     @default(0)
  sortOrder    Int     @default(0)
}

// =============================================
// 面试模板
// =============================================

model InterviewTemplate {
  id            String   @id @default(cuid())
  title         String
  description   String   @db.Text
  type          String   // technical, behavioral
  difficulty    String   // Easy, Medium, Hard
  topics        String   // JSON 数组
  estimatedTime String
  isActive      Boolean  @default(true)

  createdAt     DateTime @default(now())
}

// =============================================
// 成就系统
// =============================================

model UserAchievement {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievementKey String
  unlockedAt     DateTime @default(now())

  @@unique([userId, achievementKey])
  @@index([userId])
}

// =============================================
// 用户行为追踪
// =============================================

// 活动日志
model ActivityLog {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  type        String   // problem, interview, learning, knowledge
  title       String
  description String?
  metadata    String?  @db.Text // JSON 扩展数据

  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

// 用户文章阅读进度
model UserLearningProgress {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  articleId   String
  article     KnowledgeArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)

  status      String   @default("unread") // unread, reading, completed
  progress    Int      @default(0) // 0-100 阅读百分比
  lastReadAt  DateTime?
  completedAt DateTime?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, articleId])
  @@index([userId])
}
