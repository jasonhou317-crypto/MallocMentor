# Database (PostgreSQL)
DATABASE_URL="postgresql://username:password@localhost:5432/mallocmentor"

# NextAuth (运行 `node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"` 生成)
AUTH_SECRET="your_auth_secret_here"
AUTH_URL="http://localhost:3000"

# Coze AI 配置（每个 Bot 独立配置 TOKEN / URL / PROJECT_ID）

# AI 面试官
COZE_INTERVIEW_TOKEN=""
COZE_INTERVIEW_URL=""
COZE_INTERVIEW_PROJECT_ID=""

# 代码审查
COZE_CODE_REVIEW_TOKEN=""
COZE_CODE_REVIEW_URL=""
COZE_CODE_REVIEW_PROJECT_ID=""

# 知识助手
COZE_KNOWLEDGE_TOKEN=""
COZE_KNOWLEDGE_URL=""
COZE_KNOWLEDGE_PROJECT_ID=""

# 学习路径推荐
COZE_LEARNING_PATH_TOKEN=""
COZE_LEARNING_PATH_URL=""
COZE_LEARNING_PATH_PROJECT_ID=""

# 代码执行沙盒（默认使用 Piston 公共 API，无需配置即可运行）
# SANDBOX_PROVIDER="piston"              # piston（默认）或 judge0
# SANDBOX_API_URL=""                      # 自定义 API 地址（Piston 默认 https://emkc.org/api/v2/piston）
# SANDBOX_API_KEY=""                      # 仅 Judge0 需要
